# ── Steel Runtime Environment Variables ─────────────────────────────────────
#
# Copy this file to .env and fill in values for your deployment.
# None of these are required for local development — the app runs fully on
# mock data without any external services configured.
#
# IMPORTANT: Never commit a .env file with real secrets to version control.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express/SSR server listens on (default: 4000)
# PORT=4000

# Lock page password and token TTL. The server has built-in defaults, but
# production deployments should set these explicitly via env or secret binding.
# APP_LOCK_PASSWORD=
# APP_LOCK_TOKEN_TTL_SECONDS=3600

# ── OpenRouter Advisory Backend ───────────────────────────────────────────────
#
# When set, POST /api/rationale/* endpoints forward prompts to OpenRouter
# instead of returning static fallback text.
#
# The backend is the sole inference boundary — the browser never calls the
# model directly. LLMService on the frontend proxies through these endpoints.
#
# OpenRouter example:
#   OPENROUTER_API_KEY=sk-or-...
#   OPENROUTER_MODEL=mistral/mistral-large-2411
#
# Any OpenAI-compatible chat-completion model works if the response shape
# matches { choices: [{ message: { content: "..." } }] }.

# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=mistral/mistral-large-2411

# ── Runpod Lab Inference ──────────────────────────────────────────────────────
#
# When set, POST /api/lab/run will try the Runpod serverless endpoint first
# and fall back to Steel's local deterministic lab simulation if the remote
# job is unavailable.
#
# RUNPOD_API_KEY is a secret and should live in Secret Manager or a local .env.
# RUNPOD_ENDPOINT_ID is the Runpod serverless endpoint identifier.

# RUNPOD_API_KEY=
# RUNPOD_ENDPOINT_ID=
