# ── Steel Runtime Environment Variables ─────────────────────────────────────
#
# Copy this file to .env and fill in values for your deployment.
# None of these are required for local development — the app runs fully on
# mock data without any external services configured.
#
# IMPORTANT: Never commit a .env file with real secrets to version control.

# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express/SSR server listens on (default: 4000)
# PORT=4000

# ── LLM Advisory Backend ──────────────────────────────────────────────────────
#
# When set, POST /api/rationale/* endpoints forward prompts to this LLM
# endpoint instead of returning static fallback text.
#
# The backend is the sole inference boundary — the browser never calls the
# LLM directly. LLMService on the frontend proxies through these endpoints.
#
# Anthropic API example:
#   LLM_ENDPOINT=https://api.anthropic.com/v1/messages
#   LLM_API_KEY=sk-ant-...
#   LLM_MODEL=claude-haiku-4-5-20251001
#
# Any OpenAI-compatible endpoint works if the response shape matches
# { content: [{ text: "..." }] }.

# LLM_ENDPOINT=
# LLM_API_KEY=
# LLM_MODEL=claude-haiku-4-5-20251001
